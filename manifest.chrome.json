{
  "manifest_version": 3,
  "name": "BorealTip",
  "version": "0.1.0",
  "description": "Watch-time tipping nudges using Rumble's native wallet flow.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://rumble.com/*",
    "https://*.rumble.com/*",
    "https://pay.rumble.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://rumble.com/*", "https://*.rumble.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "BorealTip",
    "default_popup": "popup.html"
  }
}
